# ==============================================================================
# legalOS — Environment Variables
# ==============================================================================
# Copy this file to `.env.local` and fill in values. `.env.local` is git-ignored.
# Never commit real secrets.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser bundle.
# Everything else is SERVER-ONLY and must never be referenced from a client
# component or client-side fetch.
# ==============================================================================


# --- Supabase ----------------------------------------------------------------

# Supabase project URL. CLIENT-EXPOSED.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key. Safe for client-side use; constrained by RLS.
# CLIENT-EXPOSED.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key. BYPASSES Row-Level Security. SERVER-ONLY.
# Never prefix with NEXT_PUBLIC_. Never import into a client component.
SUPABASE_SERVICE_ROLE_KEY=


# --- Access gate -------------------------------------------------------------

# Optional. Comma-separated list of email addresses allowed to sign in.
# When unset or empty, all emails are allowed (permissive default — so a
# production deploy without this configured does not accidentally lock out
# all users). When set, only listed emails can request magic links or
# complete auth callbacks. Whitespace around entries is trimmed; matching
# is case-insensitive. Existing logged-in sessions are NOT re-validated
# against the allowlist — the check runs at sign-in and at callback only.
# SERVER-ONLY. Example:
#   ALLOWED_EMAILS=alice@example.com,bob@example.com
ALLOWED_EMAILS=


# --- Anthropic (wired in Phase 2) --------------------------------------------

# Anthropic API key for native agents. SERVER-ONLY.
# Never prefix with NEXT_PUBLIC_. All Claude API calls go through Next.js
# server route handlers or server actions.
ANTHROPIC_API_KEY=


# --- Site --------------------------------------------------------------------

# Public base URL for this deployment. Used by the login server action to
# build the magic-link redirect (`{SITE_URL}/auth/callback`).
#
# Local dev: http://localhost:3000 (the value below).
#
# Vercel: set in Vercel → Settings → Environment Variables, scoped to
# **Production only**, after the first deploy gives you a URL. See
# SETUP.md Part 4 (chicken-and-egg note in 4c).
#
# Resolution order in app/(public)/login/actions.ts:
#   1. NEXT_PUBLIC_SITE_URL  — Production (set explicitly in Vercel).
#   2. VERCEL_URL            — auto-injected by Vercel on every runtime
#                              (Production + Preview), unique per deploy.
#                              Server-only — DO NOT set manually anywhere,
#                              and never prefix with NEXT_PUBLIC_.
#                              Lets preview branches self-test magic-link
#                              login without per-branch env vars.
#   3. http://localhost:3000 — local dev fallback.
#
# CLIENT-EXPOSED.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
