# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- Dependencies -----------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js ----------------------------------------------------------------
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# --- Production build -------------------------------------------------------
/build

# --- Vercel -----------------------------------------------------------------
.vercel

# --- Testing ----------------------------------------------------------------
/coverage
*.lcov
playwright-report/
test-results/

# --- Environment ------------------------------------------------------------
.env*
!.env.example

# --- Debug logs -------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Supabase local dev -----------------------------------------------------
supabase/.temp/
supabase/.branches/

# --- Claude local settings --------------------------------------------------
.claude/settings.local.json

# --- OS ---------------------------------------------------------------------
.DS_Store
Thumbs.db

# --- Editor -----------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# --- Certs ------------------------------------------------------------------
*.pem

# --- Python -----------------------------------------------------------------
__pycache__/
*.pyc
